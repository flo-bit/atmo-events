{
	"name": "@atmo-dev/events-ui",
	"version": "0.1.0",
	"description": "Svelte components for atmo events (EventView, EventEditor, EventCard).",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"package": "svelte-kit sync && svelte-package -i src -o dist && publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"prepublishOnly": "pnpm package"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"svelte": "./dist/index.js",
	"peerDependencies": {
		"@foxui/core": "^0.9.0",
		"@foxui/social": "^0.8.0",
		"@foxui/text": "^0.8.0",
		"@foxui/time": "^0.8.0",
		"@foxui/visual": "^0.8.0",
		"bits-ui": "^2.16.0",
		"svelte": "^5.0.0",
		"tailwindcss": "^4.0.0"
	},
	"peerDependenciesMeta": {
		"maplibre-gl": {
			"optional": true
		},
		"svelte-maplibre-gl": {
			"optional": true
		},
		"hls.js": {
			"optional": true
		},
		"plyr": {
			"optional": true
		}
	},
	"dependencies": {
		"@atcute/bluesky-richtext-parser": "^2.1.1",
		"@atcute/tid": "^1.1.2",
		"@atmo-dev/contrail-lexicons": "^0.4.4",
		"@internationalized/date": "^3.12.0",
		"@number-flow/svelte": "^0.4.0",
		"dompurify": "^3.3.3",
		"esm-env": "^1.2.2",
		"marked": "^17.0.5",
		"svelte-boring-avatars": "^1.2.6",
		"svelte-tiptap": "^3.0.1",
		"valibot": "^1.3.1"
	},
	"devDependencies": {
		"@foxui/core": "^0.9.1",
		"@foxui/social": "^0.8.10",
		"@foxui/text": "^0.8.5",
		"@foxui/time": "^0.8.5",
		"@foxui/visual": "^0.8.7",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/package": "^2.5.5",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"bits-ui": "^2.16.3",
		"hls.js": "^1.6.15",
		"maplibre-gl": "^5.21.1",
		"plyr": "^3.8.4",
		"publint": "^0.3.16",
		"svelte": "^5.55.0",
		"svelte-check": "^4.4.8",
		"svelte-maplibre-gl": "^1.0.3",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.2",
		"vite": "^8.0.3"
	}
}
