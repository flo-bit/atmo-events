{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"declarationMap": false,
		"sourceMap": true,
		"types": ["svelte"]
	},
	"include": ["src/**/*.ts", "src/**/*.svelte"]
}
